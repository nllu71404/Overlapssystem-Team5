-- Opretter Stored Procedures
-- Creates a resident to the table of Residents.
CREATE OR ALTER PROCEDURE [dbo].[uspCreateResident]
@ResidentName NVARCHAR(100),
@MedicinTimeID INT = NULL,
@PNID INT = NULL,
@ShoppingID INT = NULL,
@ResidentStatus NVARCHAR(100) = NULL,
@Risk NVARCHAR(100)

AS
BEGIN
SET NOCOUNT ON;

    INSERT INTO dbo.Resident 
(
    ResidentName,
MedicinTimeID,
PNID,
ShoppingID,
ResidentStatus,
Risk
 )
VALUES
(
@ResidentName,
@MedicinTimeID,
@PNID,
@ShoppingID,
@ResidentStatus,
@Risk
)
SELECT SCOPE_IDENTITY() AS NewResidentID;
END;
GO

-- Deletes a resident by ID from the table
CREATE OR ALTER PROCEDURE dbo.uspDeleteResident
@ResidentID INT

AS
BEGIN
SET NOCOUNT ON;

DELETE FROM dbo.Resident
WHERE
ResidentID = @ResidentID;

END;
GO
