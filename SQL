-- Opretter Stored Procedures
CREATE OR ALTER PROCEDURE dbo.usp_AddResidentToOverlapScheme
    @OverlapSchemeID INT,
    @ResidentID INT
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    -- Check that the overlap scheme exists
    IF NOT EXISTS (
        SELECT 1
        FROM dbo.OverlapScheme
        WHERE OverlapSchemeID = @OverlapSchemeID
    )
    BEGIN
        THROW 50001, 'The specified OverlapSchemeID does not exist.', 1;
    END;

    -- Check that the resident exists
    IF NOT EXISTS (
        SELECT 1
        FROM dbo.Resident
        WHERE ResidentID = @ResidentID
    )
    BEGIN
        THROW 50002, 'The specified ResidentID does not exist.', 1;
    END;

    -- Prevent duplicate insert
    IF EXISTS (
        SELECT 1
        FROM dbo.OverlapSchemeResident
        WHERE OverlapSchemeID = @OverlapSchemeID
          AND ResidentID = @ResidentID
    )
    BEGIN
        THROW 50003, 'This resident is already assigned to the specified overlap scheme.', 1;
    END;

    -- Copy resident data into OverlapSchemeResident
    INSERT INTO dbo.OverlapSchemeResident
    (
        OverlapSchemeID,
        ResidentID,
        ResidentStatus,
        Risk,
        MedicinTimeID,
        PNID,
        ShoppingID
    )
    SELECT
        @OverlapSchemeID,
        r.ResidentID,
        r.ResidentStatus,
        r.Risk,
        r.MedicinTimeID,
        r.PNID,
        r.ShoppingID
    FROM dbo.Resident r
    WHERE r.ResidentID = @ResidentID;

    -- Optional: return the inserted row
    SELECT *
    FROM dbo.OverlapSchemeResident
    WHERE OverlapSchemeID = @OverlapSchemeID
      AND ResidentID = @ResidentID;
END;
GO

CREATE OR ALTER PROCEDURE [dbo].[uspCreateResident]
@ResidentName NVARCHAR(100),
@MedicinTimeID INT = NULL,
@PNID INT = NULL,
@ShoppingID INT = NULL,
@ResidentStatus NVARCHAR(100) = NULL,
@Risk NVARCHAR(100)

AS
BEGIN
SET NOCOUNT ON;

    INSERT INTO dbo.Resident 
(
    ResidentName,
MedicinTimeID,
PNID,
ShoppingID,
ResidentStatus,
Risk
 )
VALUES
(
@ResidentName,
@MedicinTimeID,
@PNID,
@ShoppingID,
@ResidentStatus,
@Risk
)
SELECT SCOPE_IDENTITY() AS NewResidentID;
END;
GO
