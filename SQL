CREATE TABLE dbo.MedicinTime (
MedicinTimeID INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
MeidicinTime DATETIME NULL

);
GO

CREATE TABLE dbo.PNMedicin (
PNID INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
PNTime DATETIME NULL,
Reason NVARCHAR(100) NULL,
PNTimeStamp DATETIME NULL

);
GO

CREATE TABLE dbo.Shopping (
ShoppingID INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
ShoppingDay DATE NULL,
ShoppingTime DATETIME NULL,
PaymentMethod NVARCHAR(100) NULL

);
GO

CREATE TABLE dbo.Resident (
ResidentName NVARCHAR(100),
ResidentID INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
MedicinTimeID INT FOREIGN KEY REFERENCES dbo.MedicinTime(MedicinTimeID),
PNID INT FOREIGN KEY REFERENCES dbo.PNMedicin(PNID),
ShoppingID INT FOREIGN KEY REFERENCES dbo.Shopping(ShoppingID),
ResidentStatus NVARCHAR(100),
Risk NVARCHAR(100) NULL

);
GO

CREATE TABLE dbo.OverlapScheme (
    OverlapSchemeID INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
    OverlapSchemeDate DATETIME NOT NULL
);
GO

CREATE TABLE dbo.OverlapSchemeResident (
    OverlapSchemeID INT NOT NULL,
    ResidentID INT NOT NULL,
    ResidentStatus NVARCHAR(100) NULL,
    Risk NVARCHAR(100) NULL,
    MedicinTimeID INT NULL,
    PNID INT NULL,
    ShoppingID INT NULL,

    PRIMARY KEY (OverlapSchemeID, ResidentID),

    FOREIGN KEY (OverlapSchemeID) REFERENCES dbo.OverlapScheme(OverlapSchemeID),
    FOREIGN KEY (ResidentID) REFERENCES dbo.Resident(ResidentID),
    FOREIGN KEY (MedicinTimeID) REFERENCES dbo.MedicinTime(MedicinTimeID),
    FOREIGN KEY (PNID) REFERENCES dbo.PNMedicin(PNID),
    FOREIGN KEY (ShoppingID) REFERENCES dbo.Shopping(ShoppingID)
);
GO

CREATE TABLE dbo.Department (
DepartmentName NVARCHAR(100) NOT NULL,
DepartmentID INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
ResidentID INT FOREIGN KEY REFERENCES dbo.Resident(ResidentID),
DepartmentAssignmentID INT,
TelephoneNummerID INT

);
GO


-- Opretter Stored Procedures
CREATE OR ALTER PROCEDURE [dbo].[uspCreateResident]
@ResidentName NVARCHAR(100),
@MedicinTimeID INT = NULL,
@PNID INT = NULL,
@ShoppingID INT = NULL,
@ResidentStatus NVARCHAR(100) = NULL,
@Risk NVARCHAR(100)

AS
BEGIN
SET NOCOUNT ON;

    INSERT INTO dbo.Resident 
(
    ResidentName,
MedicinTimeID,
PNID,
ShoppingID,
ResidentStatus,
Risk
 )
VALUES
(
@ResidentName,
@MedicinTimeID,
@PNID,
@ShoppingID,
@ResidentStatus,
@Risk
)
SELECT SCOPE_IDENTITY() AS NewResidentID;
END;
GO
