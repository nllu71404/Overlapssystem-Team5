@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>


<!-- Styling til skema på siderne Skoven og Slottet.razor -->
<style >
.borger-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 8px;
}

.borger-kort {
    display: flex;
    flex-direction: column;
    max-width: 250px;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    box-sizing: border-box;
}

.felt {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 10px;
    box-sizing: border-box;
}

.status-felt {
    min-height: 80px;
    resize: vertical;
}

.risiko-green {
    background-color: #c8f7d2;
    border: 2px solid #198754;
    border-left: 14px solid #198754;
    box-shadow: 0 0 6px rgba(25, 135, 84, 0.35);
}

.risiko-yellow {
    background-color: #fff0a8;
    border: 2px solid #e0a800;
    border-left: 14px solid #e0a800;
    box-shadow: 0 0 6px rgba(224, 168, 0, 0.35);
}

.risiko-red {
    background-color: #f8b8be;
    border: 2px solid #dc3545;
    border-left: 14px solid #dc3545;
    box-shadow: 0 0 6px rgba(220, 53, 69, 0.35);
}
</style>
