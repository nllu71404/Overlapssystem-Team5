@page "/Slottet"
@rendermode InteractiveServer
@using BlazorApp2test.Models
@using BlazorApp2test.Services
@inject ResidentService ResidentService

<h5>Overlap</h5>

<button @onclick="ResidentService.AddResidentSlottet">Tilføj borger</button>

<!-- Here we use the ResidentService.BorgereSlottet list, the list is called "Borgere" -->
<EditForm Model="ResidentService.BorgereSlottet">

<div class="borger-grid">
        <!-- Here we use the ResidentService.BorgereSlottet list, it is then used on each of the elements in the borger-kort div. -->
        @foreach (var borger in ResidentService.BorgereSlottet)
    {
            <div class="@($"borger-kort {ResidentHelper.GetRisikoClass(borger.Risiko)}")">
            
            <!-- Here sætter vi navn og binder værdien til borger.navn-->
            <InputText class="felt" placeholder="Navn" @bind-Value="borger.Navn" />

            <!-- Here sætter vi risiko og binder værdien til borger.Risiko-->
            <InputSelect class="felt" @bind-Value="borger.Risiko">
                <option value="Green">Grøn</option>
                <option value="Yellow">Gul</option>
                <option value="Red">Rød</option>
            </InputSelect>

            <InputText class="felt" placeholder="PN-Tid" @bind-Value="borger.PNTid" />

            <textarea class="felt status-felt" placeholder="Medicin tider" @bind="borger.MedicinTider"></textarea>

            <textarea class="felt status-felt" placeholder="Status" @bind="borger.Status"></textarea>

            <InputText class="felt" placeholder="Handledag" @bind-Value="borger.Handledag" />

            <InputText class="felt" placeholder="kr." @bind-Value="borger.Betaling" />

            <button type="button" class="btn btn-danger" @onclick="() => ResidentService.RemoveBorgerSlottet(borger)">
            Fjern borger
            </button>
        </div>
    }
</div>
</EditForm>

<style>

    .borger-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 8px;
    }

    .borger-kort {
        display: flex;
        flex-direction: column;
        max-width: 250px;
        gap: 12px;
        padding: 12px;
        border-radius: 12px;
        box-sizing: border-box;
    }

    .felt {
        width: 100%;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 10px;
        box-sizing: border-box;
    }

    .status-felt {
        min-height: 80px;
        resize: vertical;
    }

    .risiko-green {
        background-color: #c8f7d2;
        border: 2px solid #198754;
        border-left: 14px solid #198754;
        box-shadow: 0 0 6px rgba(25, 135, 84, 0.35);
    }

    .risiko-yellow {
        background-color: #fff0a8;
        border: 2px solid #e0a800;
        border-left: 14px solid #e0a800;
        box-shadow: 0 0 6px rgba(224, 168, 0, 0.35);
    }

    .risiko-red {
        background-color: #f8b8be;
        border: 2px solid #dc3545;
        border-left: 14px solid #dc3545;
        box-shadow: 0 0 6px rgba(220, 53, 69, 0.35);
    }

</style>

