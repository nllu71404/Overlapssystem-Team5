@page "/opretisystem"
@rendermode InteractiveServer
@using BlazorApp2test.Models
@using BlazorApp2test.Services
@inject BorgerCRUD BorgerCRUD


<h3>OpretISystem</h3>

<button @onclick="AddBorger">Tilføj borger</button>

@code {
    // This function adds a new borger and it graps the list from Borger.cs with the default values. This function can then be used in BorgerSide.razor to add new borgere.
    private void AddBorger()
    {
        BorgerCRUD.Borgere.Add(new BorgerModel
        {
            Navn = "Ny Borger",
            MedicinTider = "",
            PNTid = "",
            Status = "",
            Risiko = Risiko.Groen,
            Handledag = "",
            HandleTidspunkt = "",
            Betaling = 0
        });
    }

}
